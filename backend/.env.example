# =============================================================================
# EchoVision Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys.
#   cp .env.example .env
# =============================================================================

# NVIDIA API Key (https://build.nvidia.com/)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Sarvam AI API Key (https://dashboard.sarvam.ai)
SARVAM_API_KEY=your_sarvam_api_key_here

# Deepgram API Key (https://console.deepgram.com/)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Server Configuration (optional overrides)
# HOST=0.0.0.0
# PORT=8000
# DEBUG=true

# Firebase Service Account Key Path (Relative to backend directory or absolute)
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json

# Redis Connection URL
REDIS_URL=redis://localhost:6379

